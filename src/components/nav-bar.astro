---
import { siteConfig } from "@public/data/site-config";

const { ownerLogo, links } = siteConfig;
---

<header
  class="py-3 md:py-0 md:h-16 w-full md:w-3/4 md:border-2 md:border-accent rounded-md m-auto flex gap-2 flex-col md:flex-row items-center justify-between px-4 bg-secondary/50 sticky bottom-0 md:bottom-6 left-0 backdrop-blur-md z-[1000]"
>
  <h1 class="text-2xl font-semibold text-primary">{ownerLogo}</h1>

  <ul class="gap-3 flex">
    {
      Object.keys(links).map((item) => {
        //@ts-ignore
        const { name, path } = links[`${item}`];
        return (
          <li>
            <a
              href={`${path}`}
              class="text-paragraph hover:text-primary duration-300"
            >
              {name}
            </a>
          </li>
        );
      })
    }
  </ul>
</header>

<style>
  header {
    --background: var(--secondary);

    background-image: radial-gradient(
      rgba(0, 0, 0, 0) 1px,
      var(--background) 1px
    );
    background-size: 4px 4px;
  }
  h1 {
    text-shadow: 0 0 10px rgba(197, 225, 255, 0.637);
  }
</style>
