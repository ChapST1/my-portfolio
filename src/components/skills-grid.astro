---
import type { siteConfig } from "@public/data/site-config";

interface Props {
  data: (typeof siteConfig)["sections"]["skills"]["data"];
}

const { data } = Astro.props;
---

<div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 gap-4">
  {
    data.map(({ name, icon }) => {
      return (
        <>
          <article class="p-2 rounded-md border-2 border-accent  duration-300 flex flex-col gap-3 items-center justify-center hover:scale-95  group">
            <div
              set:html={icon}
              class="flex flex-col items-center justify-center gap-3"
            />
            <p set:text={name} />
          </article>
        </>
      );
    })
  }
</div>
