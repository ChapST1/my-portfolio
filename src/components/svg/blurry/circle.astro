---
import { twMerge, type ClassNameValue } from "tailwind-merge";

interface Props {
  className?: ClassNameValue;
}

const { className } = Astro.props;
---

<svg
  id="sw-js-blob-svg"
  viewBox="0 0 100 100"
  xmlns="http://www.w3.org/2000/svg"
  class={`${twMerge(
    "absolute left-[50%] top-[50%] translate-x-[-50%] translate-y-[-50%] blur-[100px] scale-75  opacity-25 -z-10",
    className,
  )}`}
>
  <defs>
    <linearGradient id="sw-gradient" x1="0" x2="1" y1="1" y2="0">
      <stop id="stop1" stop-color="rgba(189, 230, 251, 1)" offset="0%"></stop>
      <stop id="stop2" stop-color="rgba(189, 230, 251, 1)" offset="100%"></stop>
    </linearGradient>
  </defs>
  <path
    fill="url(#sw-gradient)"
    d="M26.8,-33.9C32.5,-27.2,33.2,-16.6,33.2,-7.3C33.2,2.1,32.4,10.1,28.6,16.3C24.8,22.5,18.1,26.8,11.1,28.6C4.1,30.3,-3.2,29.5,-11.6,28.1C-19.9,26.6,-29.4,24.5,-35.3,18.4C-41.2,12.3,-43.5,2.1,-40.3,-5.6C-37.1,-13.2,-28.4,-18.3,-20.7,-24.7C-13.1,-31.1,-6.5,-38.8,2,-41.2C10.6,-43.6,21.1,-40.7,26.8,-33.9Z"
    width="100%"
    height="100%"
    transform="translate(50 50)"
    stroke-width="0"
    style="transition: all 0.3s ease 0s;"
    stroke="url(#sw-gradient)"></path>
</svg>
