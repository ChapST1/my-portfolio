---
import "@fontsource/poppins";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="https://github.com/chapst1.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="m-auto max-w-screen-2xl">
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--primary: #bde6fb;
		--secondary: #1e2529;
		--accent: #2a3439;

		color-scheme: dark;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		@apply bg-secondary;
		font-family: "Poppins", sans-serif;
	}

	::-webkit-scrollbar {
		width: 10px;
	}

	::-webkit-scrollbar-track {
		background-color: var(--secondary);
	}

	::-webkit-scrollbar-thumb {
		background-color: #bde6fb79;
	}
</style>
